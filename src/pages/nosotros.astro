---
const year = new Date().getFullYear();
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Delve Educación | DeepTech</title>

        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
            rel="stylesheet"
        />

        <style>
            body {
                margin: 0;
                font-family: "Inter", sans-serif;
                background: #0f172a;
                color: white;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
                padding: 100px 20px;
                text-align: center;
            }

            h1 {
                font-size: 3rem;
                margin-bottom: 20px;
            }

            p {
                font-size: 1.2rem;
                color: #cbd5e1;
                text-align: justify;
            }

            nav {
                position: fixed;
                top: 0;
                width: 100%;
                background: rgba(15, 23, 42, 0.9);
                backdrop-filter: blur(10px);
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 40px;
                box-sizing: border-box;
                z-index: 1000;
            }

            nav ul {
                list-style: none;
                display: flex;
                gap: 30px;
                margin: 0;
                padding: 0;
            }

            nav a {
                text-decoration: none;
                color: white;
                font-weight: 500;
                transition: 0.3s;
            }

            nav a:hover {
                color: #38bdf8;
            }

            .logo img {
                height: 35px;
                width: auto;
                display: block;
            }

            .founder {
                margin-top: 80px;
                padding: 60px;
                background: #191e2d;
                border-radius: 20px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 50px;
            }

            .founder-text {
                flex: 1;
                text-align: left;
            }

            .founder-text h2 {
                font-size: 2rem;
                margin-bottom: 20px;
            }

            .founder-text p {
                color: #cbd5e1;
                line-height: 1.6;
            }

            .founder-image {
                flex: 1;
                text-align: center;
            }

            .founder-image img {
                max-width: 100%;
                border-radius: 16px;
            }

            /* HAMBURGER */
            .hamburger {
                display: none;
                flex-direction: column;
                gap: 6px;
                cursor: pointer;
            }

            .hamburger span {
                width: 25px;
                height: 3px;
                background: white;
                border-radius: 3px;
            }

            @media (max-width: 768px) {
                nav {
                    padding: 20px;
                }

                nav ul {
                    position: absolute;
                    top: 80px;
                    right: 0;
                    background: #0f172a;
                    flex-direction: column;
                    width: 220px;
                    padding: 30px;
                    gap: 20px;
                    display: none;
                }

                nav ul.active {
                    display: flex;
                }

                .hamburger {
                    display: flex;
                }

                .founder {
                    flex-direction: column;
                    text-align: center;
                }

                .founder-text {
                    text-align: center;
                }
            }

            footer {
                margin-top: 80px;
                padding: 40px 20px;
                text-align: center;
                color: #94a3b8;
                font-size: 0.9rem;
            }


        </style>
    </head>

    <body>
        <!-- NAV -->
        <nav>
            <div class="logo">
                <a href="/">
                    <img src="/assets/logo.png" />
                </a>
            </div>

            <ul id="nav-links">
                <li><a href="/ellms">Programas</a></li>
                <li><a href="/cursos">Cursos</a></li>
                <li><a href="/nosotros">Nosotros</a></li>
                <li><a href="/contacto">Contacto</a></li>
            </ul>

            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- CONTENIDO -->
        <div class="container">
            <div class="founder">
                <div class="founder-text">
                    <h2>Somos un equipo DeepTech</h2>
                    <p>
                        Somos un equipo multidisciplinario enfocado en deeptech,
                        donde convergen distintas especialidades con un objetivo
                        en común: impulsar a Latinoamérica para que juegue un
                        papel relevante en el desarrollo y aplicación de
                        tecnologías avanzadas.
                    </p>
                </div>

                <div class="founder-image">
                    <img src="/assets/team_delve.png" alt="Equipo Delve" />
                </div>
            </div>
        </div>

        <!-- FOOTER (FUERA DEL CONTAINER) -->
         <footer>
            <div class="accelerated">
                <p class="accelerated-text">Acelerados por:</p>
                <img src="/aceleratec.svg" class="accelerated-logo" />
            </div>

            <div class="social-icons">
                <a href="https://facebook.com"><img src="/facebook.webp" /></a>
                <a href="https://instagram.com"><img src="/instagram.webp" /></a>
                <a href="https://tiktok.com"><img src="/tiktok.webp" /></a>
                <a href="https://linkedin.com"><img src="/linkedin.webp" /></a>
            </div>

            <p>© {year} Delve Educación</p>
        </footer>

        <!-- SCRIPT (FUERA DEL CONTAINER) -->
        <script>
            const hamburger = document.getElementById("hamburger");
            const navLinks = document.getElementById("nav-links");

            hamburger.addEventListener("click", () => {
                navLinks.classList.toggle("active");
            });
        </script>
    </body>
</html>