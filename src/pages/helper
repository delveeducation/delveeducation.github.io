---
import logo from "../assets/logo.png";
const year = new Date().getFullYear();
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Deep Learning Avanzado | Delve Educación</title>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
    rel="stylesheet"
  />

  <style>
    body {
      margin: 0;
      font-family: "Inter", sans-serif;
      background: #0f172a;
      color: white;
    }

    /* NAVBAR ORIGINAL */

    nav {
      position: fixed;
      top: 0;
      width: 100%;
      background: rgba(15, 23, 42, 0.9);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      box-sizing: border-box;
      z-index: 1000;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 30px;
      margin: 0;
      padding: 0;
      align-items: center;
    }

    nav a {
      text-decoration: none;
      color: white;
      font-weight: 500;
      transition: 0.3s;
    }

    nav a:hover {
      color: #38bdf8;
    }

    .nav-btn {
      padding: 8px 16px;
      background: white;
      color: black !important;
      border-radius: 8px;
      font-weight: 600;
    }

    .logo img {
      height: 35px;
      width: auto;
      display: block;
    }

    /* CONTENIDO */

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 140px 20px 80px 20px;
    }

    .course-layout {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .course-main h1 {
      font-size: 2.8rem;
      margin-bottom: 15px;
    }

    .meta {
      color: #94a3b8;
      margin-bottom: 25px;
      font-size: 0.95rem;
    }

    .dot {
      margin: 0 8px;
    }

    .description {
      color: #cbd5e1;
      line-height: 1.7;
      margin-bottom: 50px;
      font-size: 1.05rem;
    }

    .section h2 {
      margin-bottom: 25px;
    }

    .module {
      background: #1e293b;
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 20px;
      transition: 0.3s ease;
    }

    .module:hover {
      background: #273449;
    }

    .module h3 {
      margin: 0 0 8px 0;
    }

    .module p {
      margin: 0;
      color: #94a3b8;
    }

    /* CARD DERECHA */

    .course-card {
      background: #1e293b;
      border-radius: 20px;
      overflow: hidden;
      position: sticky;
      top: 120px;
    }

    .course-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }

    .card-content {
      padding: 30px;
    }

    .professor {
      color: #94a3b8;
      margin-bottom: 20px;
    }

    .price {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .btn-primary {
      display: block;
      text-align: center;
      padding: 14px;
      background: #38bdf8;
      color: #0f172a;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      margin-bottom: 25px;
      transition: 0.3s ease;
    }

    .btn-primary:hover {
      transform: translateY(-3px);
    }

    .card-info {
      color: #94a3b8;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    footer {
      text-align: center;
      padding: 60px 20px;
      color: #94a3b8;
      margin-top: 80px;
    }

    /* RESPONSIVE */

    @media (max-width: 900px) {
      .course-layout {
        grid-template-columns: 1fr;
      }

      .course-card {
        position: relative;
        top: 0;
      }

      nav ul {
        gap: 15px;
      }
    }



    .relacionados {
  padding: 80px 20px;
  background-color: #f8fafc;
}

.relacionados h2 {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 50px;
  color: #0f172a;
}

.cursos-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
  max-width: 1000px;
  margin: 0 auto;
}

.curso-card {
  background: white;
  border-radius: 14px;
  padding: 20px;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
  transition: transform 0.3s ease;
}

.curso-card:hover {
  transform: translateY(-6px);
}

.curso-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  border-radius: 10px;
  margin-bottom: 20px;
}

.curso-card h3 {
  font-size: 1.2rem;
  margin-bottom: 10px;
  color: #1e293b;
}

.curso-card p {
  font-size: 0.95rem;
  color: #475569;
  margin-bottom: 20px;
}

.curso-card .btn {
  display: inline-block;
  background-color: #38bdf8;
  color: white;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
}

.curso-card .btn:hover {
  background-color: #0ea5e9;
}

/* Responsive */
@media (max-width: 768px) {
  .cursos-grid {
    grid-template-columns: 1fr;
  }
}










/* PROFESOR SECTION */

.profesor {
  margin-top: 100px;
}

.profesor-title {
  font-size: 2.3rem;
  margin-bottom: 50px;
}

.profesor-card {
  display: flex;
  align-items: center;
  gap: 60px;
  padding: 10px 0;
}

.profesor-img img {
  width: 320px;
  border-radius: 20px;
  object-fit: cover;
}

.profesor-info h3 {
  font-size: 1.8rem;
  margin-bottom: 20px;
}

.profesor-roles {
  color: #cbd5e1;
  margin-bottom: 20px;
  line-height: 1.6;
}

.profesor-info p {
  color: #94a3b8;
  margin-bottom: 15px;
  line-height: 1.7;
}

/* RESPONSIVE */

@media (max-width: 900px) {
  .profesor-card {
    flex-direction: column;
    text-align: center;
  }

  .profesor-img img {
    width: 100%;
    max-width: 300px;
  }
}












.aprendizaje {

    background: transparent; /* Mantiene tu background actual */
    color: #ffffff;
    max-width: 1200px;
    margin: auto;
  }


  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .col p {
  
    line-height: 1.6;
    margin-bottom: 18px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .aprendizaje h2 {
      font-size: 2rem;
    }
  }








            .course-grid {
