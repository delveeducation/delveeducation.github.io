                border-radius: 10px;
                text-decoration: none;
                font-weight: 600;
            }

            .course-type {
                display: inline-block;
                margin-top: 15px; /* 👈 separa del botón */
                margin-bottom: 5px;
                padding: 6px 14px;
                font-size: 0.75rem;
                font-weight: 600;
                border-radius: 20px;
                background: rgba(56, 189, 248, 0.2);
                color: #38bdf8;
                letter-spacing: 0.5px;
                border: 1px solid rgba(56, 189, 248, 0.4);
            }

  </style>
</head>

