---
const year = new Date().getFullYear();
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Delve Educación</title>

        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
            rel="stylesheet"
        />

        <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: "Inter", sans-serif;
                background: #0f172a;
                color: white;
            }

            /* NAV */
            nav {
                position: fixed;
                top: 0;
                width: 100%;
                background: rgba(15, 23, 42, 0.9);
                backdrop-filter: blur(10px);
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 40px;
                z-index: 1000;
            }

            nav ul {
                list-style: none;
                display: flex;
                gap: 30px;
                margin: 0;
                padding: 0;
                align-items: center;
            }

            nav a {
                text-decoration: none;
                color: white;
                font-weight: 500;
            }

            nav a:hover {
                color: #38bdf8;
            }

            .logo img {
                height: 35px;
            }

            /* HAMBURGER */
            .hamburger {
                display: none;
                flex-direction: column;
                gap: 6px;
                cursor: pointer;
            }

            .hamburger span {
                width: 25px;
                height: 3px;
                background: white;
                border-radius: 3px;
            }

            /* CONTAINER */
            .container {
                max-width: 1200px;
                margin: 0 auto;
                padding: 110px 20px 80px;
            }

            /* GRID PRINCIPAL (CLEAN) */
            .course-layout {
                display: grid;
                grid-template-columns: 2fr 1fr;
                grid-template-areas:
                    "header card"
                    "main card";
                gap: 50px;
                align-items: start;
            }

            .course-header {
                grid-area: header;
            }

            .course-main {
                grid-area: main;
            }

            .course-card {
                grid-area: card;
                background: #1e293b;
                border-radius: 20px;
                padding: 20px;
                position: sticky;
                top: 120px;
                height: fit-content;
            }

            .course-card img {
                width: 100%;
                border-radius: 12px;
                height: 220px;
                object-fit: cover;
            }
            .course-card {
                position: sticky;
                top: 120px;
            }

            @media (max-width: 900px) {
                .course-card {
                    position: static; /* mejor que relative aquí */
                }
            }
            /* TEXTOS */
            .meta {
                color: #94a3b8;
                margin-bottom: 20px;
            }

            .description {
                color: #cbd5e1;
                line-height: 1.7;
            }

            /* MODULES */
            .module {
                background: #1e293b;
                padding: 20px;
                border-radius: 12px;
                margin-bottom: 20px;
            }

            .module p {
                color: #94a3b8;
                line-height: 1.6;
            }

            /* PROFESORES */
            .profesor-card {
                display: flex;
                gap: 40px;
                margin-bottom: 40px;
            }

            .profesor-img img {
                width: 180px;
                border-radius: 16px;
            }

            .profesor-roles {
                color: #cbd5e1;
                line-height: 1.6;
            }

            /* GRID APRENDIZAJE */
            .aprendizaje {
                margin-bottom: 60px;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 30px;
            }

            .col p {
                margin-bottom: 10px;
                color: #cbd5e1;
            }

            /* BOTONES */
            .btn-primary {
                display: block;
                text-align: center;
                padding: 14px;
                background: #00ffee;
                color: #0f172a;
                border-radius: 12px;
                text-decoration: none;
                font-weight: 600;
                margin: 20px 0;
            }

            /* RESPONSIVE */
            @media (max-width: 900px) {
                .course-layout {
                    grid-template-columns: 1fr;
                    grid-template-areas:
                        "header"
                        "card"
                        "main";
                }

                .grid {
                    grid-template-columns: 1fr;
                }

                .profesor-card {
                    flex-direction: column;
                }

                nav ul {
                    display: none;
                    position: absolute;
                    top: 80px;
                    right: 0;
                    background: #0f172a;
                    flex-direction: column;
                    padding: 20px;
                    width: 200px;
                    border-radius: 10px;
                }

                nav ul.active {
                    display: flex;
                }

                .hamburger {
                    display: flex;
                }
            }

            footer {
                text-align: center;
                padding: 60px 20px;
                color: #94a3b8;
            }
        </style>
    </head>

    <body>
        <nav>
            <div class="logo">
                <a href="/"><img src="/assets/logo.png" /></a>
            </div>

            <ul id="nav-links">
                <li><a href="/ellms">Programas</a></li>
                <li><a href="/cursos">Cursos</a></li>
                <li><a href="/nosotros">Nosotros</a></li>
                <li><a href="/contacto">Contacto</a></li>
            </ul>

            <div class="hamburger" id="hamburger">
                <span></span><span></span><span></span>
            </div>
        </nav>

        <div class="container">
            <div class="course-layout">
                <!-- HEADER -->
                <div class="course-header">
                    <h3 style="color:#00FFEE;">PROGRAMA</h3>
                    <h1 style="color:#00FFEE;">Especialista en LLMs</h1>

                    <div class="meta">
                        De Fundamentos a Aplicaciones Reales • 4 Semanas
                    </div>

                    <p class="description">
                        Aprende a construir aplicaciones modernas con LLMs, RAG
                        y optimización avanzada.
                    </p>
                </div>

                <!-- CARD -->
                <div class="course-card">
                    <img src="/assets/cursos/ellms_web.png" />

                    <p style="color:#94a3b8;">
                        Profesores: Martin Arispe, Camilo Bolaños, Edison
                        Bejarano y Fernando Silva
                    </p>

                    <a href="#" class="btn-primary">Inscribirme Ahora</a>

                    <p style="color:#94a3b8; font-size: 0.9rem;">
                        ✔ Acceso anual <br />
                        ✔ Certificado oficial
                    </p>
                </div>

                <!-- MAIN -->
                <div class="course-main">
                    <section class="aprendizaje">
                        <h2>¿Qué aprenderás?</h2>

                        <div class="grid">
                            <div class="col">
                                <p>
                                    • Fundamentos de Large Language Models
                                    (LLMs)
                                </p>
                                <p>• Arquitectura Transformer</p>
                            </div>

                            <div class="col">
                                <p>• Prompt Engineering aplicado</p>
                                <p>• Sistemas RAG de alto rendimiento</p>
                            </div>

                            <div class="col">
                                <p>• Fine-tuning y evaluación de modelos</p>
                                <p>• Cuantización e inferencia eficiente</p>
                            </div>
                        </div>
                    </section>

                    <h2>Contenido</h2>

                    <div class="module">
                        <h3>Bloque 1: Fundamentos de LLMs</h3>
                        <p>
                            Comprenderás cómo funcionan los Large Language
                            Models desde la arquitectura Transformer y los
                            mecanismos de self-attention hasta conceptos
                            fundamentales como embeddings, tokenización y
                            prompting moderno.
                        </p>
                    </div>

                    <div class="module">
                        <h3>Bloque 2: LLMs Locales</h3>
                        <p>
                            Aprenderás a ejecutar modelos open-source de forma
                            local utilizando herramientas modernas para
                            construir aplicaciones prácticas como chatbots,
                            sistemas de clasificación, asistentes inteligentes y
                            generación automática de texto.
                        </p>
                    </div>

                    <div class="module">
                        <h3>Bloque 3: LLMs Avanzado</h3>
                        <p>
                            Explorarás técnicas avanzadas para optimizar y
                            adaptar modelos de lenguaje utilizando cuantización,
                            LoRA, QLoRA, fine-tuning eficiente e inferencia
                            optimizada para producción.
                        </p>
                    </div>

                    <div class="module">
                        <h3>Bloque 4: Aplicaciones con LLMs</h3>
                        <p>
                            Aplicarás los conceptos aprendidos mediante
                            ejercicios guiados, implementación de proyectos
                            prácticos y resolución de casos reales utilizando
                            sistemas modernos basados en LLMs.
                        </p>
                    </div>
                    <br />
                    <h2>Descripción</h2>
                    <p class="description">
                        Desarrollarás una comprensión sólida de los Large
                        Language Models (LLMs), desde sus fundamentos teóricos
                        hasta técnicas modernas utilizadas en sistemas de
                        inteligencia artificial generativa. A lo largo del
                        programa aprenderás a trabajar con modelos open-source,
                        construir sistemas RAG, optimizar inferencia mediante
                        cuantización y desplegar aplicaciones reales tanto en
                        entornos locales como escalables. El programa combina
                        fundamentos técnicos con implementación práctica,
                        permitiéndote desarrollar experiencia aplicada en
                        tecnologías modernas utilizadas en la industria de IA.
                    </p>

                    <br />
                    <br />
                    <h2>Metodología</h2>
                    <p class="description">
                        El programa se desarrolla bajo una metodología de
                        Blended Learning, combinando aprendizaje autónomo y
                        sesiones prácticas en vivo. De lunes a viernes avanzarás
                        mediante contenido audiovisual estructurado, mientras
                        que los sábados participarás en clases en tiempo real
                        enfocadas en implementación práctica, resolución de
                        dudas y desarrollo de proyectos guiados.
                    </p>

                    <br /><br />
                    <h2>Profesores</h2>
                    <div class="profesor-card">
                        <div class="profesor-img">
                            <img
                                src="/assets/mentores/martin_arispe.jpg"
                                alt="Martin Arispe"
                            />
                        </div>

                        <div class="profesor-info">
                            <h3>Martin Arispe</h3>

                            <p class="profesor-roles">
                                Especialista en Inteligencia Artificial con
                                experiencia en Agentes de IA, Large Language
                                Models (LLMs) y Knowledge Graphs. Ha liderado la
                                implementación de flujos de trabajo con
                                Generative AI y plataformas impulsadas por IA.
                                Participó en el proyecto MINTE en Fraunhofer
                                IAIS (Alemania), integrando Deep Learning y
                                Knowledge Graphs.
                            </p>
                        </div>
                    </div>
                    <div class="profesor-card">
                        <div class="profesor-img">
                            <img
                                src="/assets/mentores/camilo_bolanios.png"
                                alt="Camilo Bolaños"
                            />
                        </div>

                        <div class="profesor-info">
                            <h3>Camilo Bolaños</h3>

                            <p class="profesor-roles">
                                Ingenierio Mecatrónico con una Maestría en
                                Mecatrónica, Robótica e Ingeniería de
                                Automatización por la Universidad de Valladolid.
                                Cuenta con más de 7 años en desarrollo Backend
                                aplicado a soluciones de Inteligencia Artificial
                                en diversos paises en Europa.
                            </p>
                        </div>
                    </div>

                    <div class="profesor-card">
                        <div class="profesor-img">
                            <img
                                src="/assets/mentores/edison_bejarano.png"
                                alt="Edison Bejarano"
                            />
                        </div>

                        <div class="profesor-info">
                            <h3>Edison Bejarano</h3>

                            <p class="profesor-roles">
                                Ingeniero Aeroespacial con un Máster en
                                Inteligencia Artificial y experiencia en
                                investigación avanzada en modelos de lenguaje
                                aplicados a robótica en la UPC. Actualmente
                                trabaja en el desarrollo de soluciones de IA y
                                LLMs en el ITCL, combinando investigación
                                académica con aplicaciones tecnológicas en
                                entornos industriales reales.
                            </p>
                        </div>
                    </div>

                    <div class="profesor-card">
                        <div class="profesor-img">
                            <img
                                src="/assets/mentores/fernando_silva.jpg"
                                alt="Fernando Silva"
                            />
                        </div>

                        <div class="profesor-info">
                            <h3>Fernando Silva</h3>

                            <p class="profesor-roles">
                                Es ingeniero en sistemas con un máster en
                                inteligencia artificial realizado en Europa.
                                Tiene experiencia en proyectos de machine
                                learning, visión por computadora y procesamiento
                                de lenguaje natural en empresas y organizaciones
                                en Latinoamérica y Europa.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>

    <footer>
        © {year} Delve Educación
    </footer>

    <script>
        const hamburger = document.getElementById("hamburger");
        const navLinks = document.getElementById("nav-links");

        hamburger.addEventListener("click", () => {
            navLinks.classList.toggle("active");
        });
    </script>
</html>
