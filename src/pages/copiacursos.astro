                        class="course-image"
                    />

                    <h3>Large Language Models</h3>
                    <p class="professor">Prof. Martin Arispe</p>

                    <a href="/llms" class="btn">Ver programa</a>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/large_language_models_locales.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Large Language Models Locales</h3>
                    <p class="professor">Prof. Martin Arispe</p>

                    <a href="/llml" class="btn">Ver programa</a>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <!-- -->

                <div class="course-card">
                    <img
