                    <h3>Large Language Models Avanzado</h3>
                    <p class="professor">Prof. Edison Bejarano</p>

                    <!--<a href="/llma" class="btn">Ver programa</a>-->
                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/self_supervised_learning.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Self-Supervised Learning</h3>
                    <p class="professor">Prof. Imanol Estepa</p>

                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/computer_vision_3d.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Computer Vision 3D</h3>
                    <p class="professor">Prof. Emily Rivera</p>

                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/human_pose_estimation.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Human Pose Estimation</h3>
                    <p class="professor">Prof. Emily Rivera</p>

                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/multimodal_ai.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Multimodal AI</h3>
                    <p class="professor">Prof. Artemis Llabrés</p>

                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="/ejemplo_nn.jpg"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Social Data Science</h3>
                    <p class="professor">Prof. Alex Ojeda</p>

                    <span>Muy Pronto</span>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <!--

                <div class="course-card">
                    <img
                        src="/ejemplo_nn.jpg"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Tensor Networks</h3>
                    <p class="professor">Prof. ?????</p>

                    <a href="/fdl" class="btn">Ver programa</a>

                    <span class="course-type">Computación Cuántica</span>
                </div>



                <div class="course-card">
                    <img
                        src="/ejemplo_nn.jpg"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Procesamiento de Información Cuántica</h3>
                    <p class="professor">Prof. ?????</p>

                    <a href="/fdl" class="btn">Ver programa</a>

                    <span class="course-type">Computación Cuántica</span>
                </div>




 -->
            </div>
        </div>

        <footer>
            © {year} Delve Educación
        </footer>
    </body>
</html>
