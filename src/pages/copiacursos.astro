                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/fundamentos_de_deep_learning.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Fundamentos de Deep Learning</h3>
                    <p class="professor">Prof. Oscar Contreras</p>

                    <a href="/fdl" class="btn">Ver programa</a>

                    <span class="course-type-AI">Inteligencia Artificial</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/introduccion_a_computer_vision.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Introducción a Computer Vision</h3>
                    <p class="professor">Prof. Emily Rivera</p>

                    <a href="/icv" class="btn">Ver programa</a>

