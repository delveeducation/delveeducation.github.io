---
import logo from "../assets/logo.png";
const year = new Date().getFullYear();
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Cursos | Delve Educación</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                margin: 0;
                font-family: "Inter", sans-serif;
                background: #0f172a;
                color: white;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
                padding: 120px 20px 80px 20px;
            }

            h1 {
                font-size: 2.5rem;
                margin-bottom: 20px;
            }

            p {
                color: #cbd5e1;
            }

            .course-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 30px;
                margin-top: 60px;
            }

            @media (max-width: 1100px) {
                .course-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (max-width: 600px) {
                .course-grid {
                    grid-template-columns: 1fr;
                }
            }

            .course-card {
                background: #1e293b;
                padding: 20px;
                border-radius: 20px;
                transition: 0.3s ease;
            }

            .course-card:hover {
                transform: translateY(-5px);
                background: #273449;
            }

            .course-card h3 {
                margin-bottom: 15px;
            }

            .btn {
                display: inline-block;
                margin-top: 20px;
                padding: 10px 20px;
                background: white;
                color: black;
                border-radius: 10px;
                text-decoration: none;
                font-weight: 600;
            }

            .course-type-AI {
                display: inline-block;
                margin-top: 15px; /* 👈 separa del botón */
                margin-bottom: 5px;
                padding: 6px 14px;
                font-size: 0.75rem;
                font-weight: 600;
                border-radius: 20px;
                background: rgba(56, 189, 248, 0.2);
                color: #ffffff;
                letter-spacing: 0.5px;
                border: 1px solid rgba(56, 189, 248, 0.4);
            }

            .course-type-programming {
                display: inline-block;
                margin-top: 15px; /* 👈 separa del botón */
                margin-bottom: 5px;
                padding: 6px 14px;
                font-size: 0.75rem;
                font-weight: 600;
                border-radius: 20px;
                background: rgba(56, 189, 248, 0.2);
                color: #ffffff;
                letter-spacing: 0.5px;
                border: 1px solid rgba(56, 189, 248, 0.4);
            }

            .course-type-quantum {
                display: inline-block;
                margin-top: 15px; /* 👈 separa del botón */
                margin-bottom: 5px;
                padding: 6px 14px;
                font-size: 0.75rem;
                font-weight: 600;
                border-radius: 20px;
                background: rgba(56, 189, 248, 0.2);
                color: #ffffff;
                letter-spacing: 0.5px;
                border: 1px solid rgba(56, 189, 248, 0.4);
            }

            .course-type-soon {
                display: inline-block;
                margin-top: 15px; /* 👈 separa del botón */
                margin-bottom: 5px;
                padding: 6px 14px;
                font-size: 0.75rem;
                font-weight: 600;
                border-radius: 20px;
                background: rgb(216, 216, 0);
                color: #ffffff;
                letter-spacing: 0.5px;
                border: 1px solid rgba(255, 255, 255, 0);
            }

            nav {
                position: fixed;
                top: 0;
                width: 100%;
                background: rgba(15, 23, 42, 0.9);
                backdrop-filter: blur(10px);
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 40px;
                box-sizing: border-box;
            }

            nav ul {
                list-style: none;
                display: flex;
                gap: 30px;
                margin: 0;
            }

            nav a {
                text-decoration: none;
                color: white;
            }

            .logo img {
                height: 35px;
            }

            footer {
                text-align: center;
                padding: 40px;
                color: #94a3b8;
            }

            .course-image {
                width: 100%;
                height: 200px; /* 👈 tamaño fijo */
                object-fit: cover; /* 👈 recorta sin deformar */
            }
        </style>
    </head>

    <body>
        <nav>
            <div class="logo">
                <a href="/">
                    <img src={logo.src} alt="Delve Educación Logo" />
                </a>
            </div>

            <ul>
                <li><a href="/">Inicio</a></li>
                <li><a href="/cursos">Cursos</a></li>
            </ul>
        </nav>

        <div class="container">
            <h1>Nuestros Cursos 🚀</h1>
            <p>Programas diseñados para formar líderes en DeepTech.</p>

            <div class="course-grid">
                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/python_practico.png"
                        alt="Deep Learning"
                        class="course-image"
                    />

                    <h3>Python <br />Práctico</h3>
                    <p class="professor">Prof. Diego Angulo</p>

                    <a href="/pp" class="btn">Ver programa</a>

                    <span class="course-type-programming">Programación</span>
                </div>

                <div class="course-card">
                    <img
                        src="../../src/assets/cursos/algoritmos_y_estructura_de_datos.png"
                        alt="Algoritmos y Estructuras de Datos"
                        class="course-image"
                    />

                    <h3>Algoritmos y Estructura de Datos</h3>
                    <p class="professor">Prof. Diego Angulo</p>

                    <a href="/aed" class="btn">Ver programa</a>

                    <span class="course-type-programming">Programación</span>
                </div>

                <div class="course-card">
